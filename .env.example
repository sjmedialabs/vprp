# VPRP Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===================
# Supabase Configuration
# ===================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# Public anon JWT from Supabase Dashboard > Settings > API (Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Postgres connection strings (Dashboard > Settings > Database)
# Use the connection string Supabase shows for your client (direct vs pooler).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Configure in Supabase dashboard (Authentication > Providers)
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your_google_client_id
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===================
# Razorpay Configuration
# ===================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ===================
# Mailchimp Configuration
# ===================
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_default_audience_list_id

# ===================
# Application Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ===================
# Optional Feature Flags
# ===================
NEXT_PUBLIC_ENABLE_OTP_LOGIN=true
